# ZeroClaw Gateway 地址
# 注意: 如果从其他设备访问,请使用实际 IP 地址而非 localhost
ZEROCLOW_GATEWAY_URL=http://localhost:42617

# Web Chat 服务器端口
PORT=3332

# Gateway 配对令牌（从 config.toml 的 gateway.paired_tokens 获取）
#ZEROCLOW_TOKEN=

# 页面访问密钥（建议修改为更复杂的密钥）
ACCESS_KEY=zeroclaw2026

# 会话有效期（毫秒，默认 12 小时）
#SESSION_TTL_MS=43200000

# 允许跨域的来源列表（逗号分隔；留空表示不允许跨域）
#ALLOWED_ORIGINS=https://zero.wenyinos.com,http://localhost:3332

# 登录验证限流（默认：10次/10分钟，超限封禁15分钟）
#VERIFY_MAX_ATTEMPTS=10
#VERIFY_WINDOW_MS=600000
#VERIFY_BLOCK_MS=900000
